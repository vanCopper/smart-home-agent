# Hub Node.js server address (internal API)
HUB_URL=http://127.0.0.1:3300

# OpenClaw session to send text to
OPENCLAW_SESSION=agent:main:main

# Wake words (comma-separated, matched against Whisper transcript of short chunks)
WAKE_WORDS=小管家,hey home

# ASR model — "mlx-community/whisper-large-v3-mlx" for best quality,
#              "mlx-community/whisper-small-mlx" for lower latency
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# TTS model — Fish Speech S2 Pro (MLX quantized, local)
TTS_MODEL=mlx-community/fishaudio-s2-pro-8bit-mlx

# Reference voice for cloning (relative to voice-agent/ directory)
# Record 30~60s of clear target audio, save as ref_voices/<name>.wav
# Corresponding transcript text for the reference audio:
REF_VOICE_PATH=ref_voices/shinchan.wav
REF_VOICE_TEXT=

# USB mic device index (leave empty to use system default)
# Run `python -c "import sounddevice; print(sounddevice.query_devices())"` to list
MIC_DEVICE_INDEX=

# Silence detection: stop recording after N seconds of silence
VAD_SILENCE_SEC=0.8

# Max recording duration before forced cut-off (seconds)
MAX_RECORD_SEC=12
